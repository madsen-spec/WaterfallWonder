# Baseline security headers for Cloudflare Pages static responses.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), geolocation=(), microphone=(), payment=(), usb=()
  Content-Security-Policy: frame-ancestors 'none'; object-src 'none'; base-uri 'self'; upgrade-insecure-requests

# Keep Cloudflare's generated Pages addresses out of search results. The
# custom domain remains indexable.
https://:project.pages.dev/*
  X-Robots-Tag: noindex, nofollow

https://:deployment.:project.pages.dev/*
  X-Robots-Tag: noindex, nofollow
